#!/usr/bin/env bash
set -euo pipefail

PACKAGE_PATH="artifacts/packages/WoadStoat.MarkovNames.0.1.0.nupkg"
SOURCE="https://api.nuget.org/v3/index.json"

if [ -z "${NUGET_API_KEY:-}" ]; then
  echo "NUGET_API_KEY environment variable is not set."
  exit 1
fi

dotnet nuget push "$PACKAGE_PATH" \
  --api-key "$NUGET_API_KEY" \
  --source "$SOURCE"